# Database Configuration - MySQL
MYSQL_ROOT_PASSWORD=your_secure_mysql_password_here
MYSQL_DATABASE=microservices

# Database Configuration - PostgreSQL
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=microservice

# AuthService Database
AUTH_DB_URL=jdbc:mysql://localhost:3306/auth_service_db
AUTH_DB_USERNAME=root
AUTH_DB_PASSWORD=your_secure_password_here

# UserService Database
USER_DB_URL=jdbc:mysql://localhost:3306/microservices
USER_DB_USERNAME=root
USER_DB_PASSWORD=your_secure_password_here

# HotelService Database
HOTEL_DB_URL=jdbc:postgresql://localhost:5432/microservice
HOTEL_DB_USERNAME=postgres
HOTEL_DB_PASSWORD=your_secure_password_here

# RatingService Database
RATING_DB_URL=jdbc:mysql://localhost:3306/rating_service
RATING_DB_USERNAME=root
RATING_DB_PASSWORD=your_secure_password_here

# JWT Configuration
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MINIMUM_64_CHARACTERS_LONG
JWT_EXPIRATION=900000

# Eureka Security
EUREKA_USERNAME=admin
EUREKA_PASSWORD=your_secure_eureka_password_here

# Config Server Security
CONFIG_SERVER_USERNAME=config_admin
CONFIG_SERVER_PASSWORD=your_secure_config_password_here

# ELK Stack Security
ELASTIC_PASSWORD=your_secure_elastic_password_here
KIBANA_PASSWORD=your_secure_kibana_password_here

# Eureka Client Configuration
# Format: http://username:password@host:port/eureka/
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://abc:abc123@localhost:8761/eureka/

# Logstash Configuration
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5000
