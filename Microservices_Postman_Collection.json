              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Grand Hotel Updated\",\n  \"location\": \"Mumbai\",\n  \"about\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{hotelUrl}}/hotels/{{hotelId}}",
              "host": ["{{hotelUrl}}"],
              "path": ["hotels", "{{hotelId}}"]
