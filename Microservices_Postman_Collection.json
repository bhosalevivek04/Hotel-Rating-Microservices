    {
      "name": "6. Complete Flow Test",
      "item": [
        {
          "name": "Step 1: Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Registration successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.exist;",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "    pm.collectionVariables.set('userId', jsonData.userId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"flow_test_{{$timestamp}}\",\n  \"password\": \"password123\",\n  \"email\": \"flowtest{{$timestamp}}@example.com\",\n  \"name\": \"Flow Test User\",\n  \"about\": \"Testing complete flow\"\n}"
            },
            "url": {
              "raw": "{{authUrl}}/auth/register",
              "host": ["{{authUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Step 2: Create Hotel",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Hotel created', function() {",
                  "    pm.response.to.have.status(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('hotelId', jsonData.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Hotel {{$timestamp}}\",\n  \"location\": \"Mumbai\",\n  \"about\": \"Test hotel for flow\"\n}"
            },
            "url": {
              "raw": "{{hotelUrl}}/hotels",
              "host": ["{{hotelUrl}}"],
              "path": ["hotels"]
            }
          }
        },
        {
          "name": "Step 3: Create Rating",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rating created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"hotelId\": \"{{hotelId}}\",\n  \"rating\": 5,\n  \"feedback\": \"Excellent!\"\n}"
            },
            "url": {
              "raw": "{{ratingUrl}}/ratings",
              "host": ["{{ratingUrl}}"],
              "path": ["ratings"]
            }
          }
        },
        {
          "name": "Step 4: Get Complete User Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User data retrieved with ratings and hotels', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.ratings).to.be.an('array');",
                  "    pm.expect(jsonData.ratings.length).to.be.above(0);",
                  "    pm.expect(jsonData.ratings[0].hotel).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{userUrl}}/users/{{userId}}",
              "host": ["{{userUrl}}"],
              "path": ["users", "{{userId}}"]
            }
          }
        }
      ]
