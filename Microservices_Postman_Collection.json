        },
        {
          "name": "Delete Hotel",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{hotelUrl}}/hotels/{{hotelId}}",
              "host": ["{{hotelUrl}}"],
              "path": ["hotels", "{{hotelId}}"]
            }
          }
        }
